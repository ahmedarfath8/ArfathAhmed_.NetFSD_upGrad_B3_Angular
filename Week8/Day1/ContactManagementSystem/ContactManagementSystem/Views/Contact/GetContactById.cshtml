@model ContactInfo

<h1>Details</h1>

<div class="form-group">
    <label>First Name:</label>
    <p>@Model.FirstName</p>
</div>

<div class="form-group">
    <label>Last Name:</label>
    <p>@Model.LastName</p>
</div>

<div class="form-group">
    <label>Email:</label>
    <p>@Model.EmailId</p>
</div>

<div class="form-group">
    <label>Mobile:</label>
    <p>@Model.MobileNo</p>
</div>

<div class="form-group">
    <label>Designation:</label>
    <p>@Model.Designation</p>
</div>

<div class="form-group">
    <label>Company:</label>
    <p>@Model.CompanyName</p>
</div>

<div class="form-group">
    <label>Department:</label>
    <p>@Model.DepartmentName</p>
</div>

<a asp-action="EditContact" asp-route-id="@Model.ContactId" class="btn btn-warning">Update</a>
<a asp-action="ShowContacts" class="btn btn-secondary">Back</a>