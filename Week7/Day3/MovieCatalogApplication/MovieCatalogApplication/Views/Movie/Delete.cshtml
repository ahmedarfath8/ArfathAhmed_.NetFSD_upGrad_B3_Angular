@model Movie

@{
    ViewData["Title"] = "Delete";
}
<h1>Delete</h1>
<h4>Are you sure you want to delete this Movie?</h4>

<form asp-action="Delete" method="post">

    <input type="hidden" asp-for="Id" />

    <p><b>Title:</b> @Model.Title</p>
    <p><b>Genre:</b> @Model.Genre</p>
    <p><b>Release Date:</b> @Model.ReleaseDate</p>
    <p><b>Price:</b> @Model.Price</p>
    <p><b>Rating:</b> @Model.Rating</p>

    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-primary">No</a>
</form>
<div>
    <a asp-action="Index">Back to Movies</a>
</div>


